{
  "info": {
    "_postman_id": "0298bb07-d117-4662-8fa4-e1a4520e7d8c",
    "name": "Mini Project 2: Automating API Test Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "10803406"
  },
  "item": [
    {
      "name": "Login(Extract Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.test(\"Token is present and set as environment variable\", function () {\r",
              "        pm.expect(jsonData).to.have.property('token')\r",
              "        pm.environment.set(\"token\", jsonData.token);\r",
              "        console.log(\"response token:\", jsonData.token)\r",
              "        console.log(\"Environment token:\", pm.environment.get('token'))\r",
              "\r",
              "    });\r",
              "} else {\r",
              "    pm.environment.unset(\"token\");\r",
              "\r",
              "\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"runStartTime\",new Date().toISOString());\r",
              "console.log(\"Run Started at: \", pm.environment.get(\"runStartTime\"));\r",
              "console.log(\"Test environment: \",pm.environment.name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "reqres_5265b748bca64900bdd45ebf925f2a98",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"email\": \"byron.fields@reqres.in\",\r\n    \"password\": \"cityslicka\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "CreateUser",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful POST request\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 202]);\r",
              "});\r",
              "\r",
              "if (pm.expect(pm.response.code).to.be.oneOf([201, 202])) {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.test(\"Test to fetch UserId & assign it to environment variable\", function(){\r",
              "    pm.environment.set(\"UserId\", jsonData.id);\r",
              "    console.log('Response Id', jsonData.id);\r",
              "    console.log('Environment ID', pm.environment.get(\"UserId\"));\r",
              "    });\r",
              "}\r",
              "else {\r",
              "    pm.environment.unset(\"UserId\");\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "reqres_5265b748bca64900bdd45ebf925f2a98",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{Name}}\",\r\n    \"job\": \"{{Job}}\"\r\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      },
      "response": []
    },
